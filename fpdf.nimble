# Package
version       = "0.1.0"
author        = "akvilary"
description   = "Pure Nim PDF generation library — create PDF documents with text, fonts, graphics, and images. Inspired by the PHP FPDF API."
license       = "MIT"
srcDir        = "src"

# Dependencies
requires "nim >= 2.0.0"
requires "zippy >= 0.10.0"
requires "nimPNG >= 0.3.0"
